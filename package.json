{
	"name": "widi",
	"private": true,
	"type": "module",
	"workspaces": [
		"pi/packages/ai",
		"pi/packages/agent",
		"pi/packages/tui",
		"apps/widi-pi"
	],
	"scripts": {
		"clean": "npm run clean --workspaces",
		"build": "npm --workspace pi/packages/ai run build && npm --workspace pi/packages/agent run build && npm --workspace pi/packages/tui run build && npm --workspace apps/widi-pi run build",
		"check": "biome check --write --error-on-warnings . && tsgo --noEmit -p tsconfig.json",
		"test": "npm run test --workspaces --if-present"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@types/node": "^22.10.5",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"shx": "^0.4.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"version": "0.0.3",
	"dependencies": {
		"scripts": "^0.1.0"
	}
}