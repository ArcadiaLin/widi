{
  "name": "widi-pi",
  "version": "0.0.0",
  "private": true,
  "description": "WIDI Pi is a terminal coding harness based on the pi-agent-core",
  "type": "module",
  "bin": {
    "widi-harness": "dist/cli.js"
  },
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "npm run build:deps && npm run build:app",
    "build:app": "tsgo -p tsconfig.build.json",
    "build:deps": "tsgo -p ../../pi/packages/ai/tsconfig.build.json && tsgo -p ../../pi/packages/agent/tsconfig.build.json && tsgo -p ../../pi/packages/tui/tsconfig.build.json",
    "check": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "cli": "tsx --tsconfig tsconfig.json src/cli.ts",
    "tui": "tsx --tsconfig tsconfig.json src/cli.ts --cwd \"$INIT_CWD\" --agent-dir \"$npm_config_local_prefix/.widi\" --profile widi-dev"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "diff": "8.0.4",
    "jiti": "^2.7.0",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "^5.7.1",
    "@types/node": "^24.3.0",
    "tsx": "^4.23.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
