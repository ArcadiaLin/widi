{
  "name": "widi-pi",
  "version": "0.0.0",
  "private": true,
  "description": "WIDI Pi is a terminal coding harness based on the pi-agent-core",
  "type": "module",
  "scripts": {
    "clean": "shx rm -rf dist",
    "build": "tsgo -p tsconfig.build.json",
    "check": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest --run",
    "cli": "tsx --tsconfig tsconfig.json src/cli.ts"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.79.9",
    "@earendil-works/pi-ai": "^0.79.9",
    "@earendil-works/pi-tui": "^0.79.9",
    "diff": "8.0.4",
    "dotenv": "^17.4.2",
    "jiti": "^2.7.0",
    "openai": "^6.26.0",
    "smol-toml": "^1.6.1",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "^5.7.1",
    "@types/node": "^24.3.0",
    "tsx": "^4.23.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
